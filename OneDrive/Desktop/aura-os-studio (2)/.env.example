# ============================================================================
# AURA OS STUDIO - Production Environment Configuration
# ============================================================================
# DO NOT commit actual secrets to git!
# Copy this to .env.local and fill in real values
# ============================================================================

# Server Configuration
NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# JWT Authentication (Required - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=GENERATE_A_RANDOM_32_BYTE_HEX_STRING_HERE
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# Database Configuration (Real Database - PostgreSQL, MongoDB, etc.)
# Option 1: PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/aura_os_studio

# Option 2: MongoDB
# DATABASE_URL=mongodb://user:password@localhost:27017/aura_os_studio

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# Webhook Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=GENERATE_A_RANDOM_32_BYTE_HEX_STRING_HERE

# GitHub Integration (Real API Access)
# Get from: https://github.com/settings/personal-access-tokens/new
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_WEBHOOK_SECRET=GENERATE_A_RANDOM_32_BYTE_HEX_STRING_HERE

# Real AI/LLM Services (Only if actually using)
# Option 1: Google Gemini
GEMINI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Option 2: OpenAI
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_ORG_ID=org-XXXXXXXXXXXXXXXXXXXXXXXXX

# Option 3: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Local Development Only: Ollama (Self-hosted LLM)
# OLLAMA_BASE_URL=http://localhost:11434

# Logging & Monitoring
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true

# Session Configuration
SESSION_STORE=memory  # Use 'redis' for production with multiple instances
SESSION_EXPIRY=24h

# Rate Limiting (per 15 minutes)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# File Upload Limits
MAX_FILE_SIZE=104857600  # 100MB
MAX_PROJECT_SIZE=1073741824  # 1GB

# Security: API Key Validation
REQUIRE_API_KEYS=true
ALLOWED_API_KEY_REGEX=^[a-zA-Z0-9_-]{32,}$

# ============================================================================
# ⚠️ DEPRECATED/REMOVED: These no longer exist
# ============================================================================
# Firebase is removed - use DATABASE_URL instead
# FIREBASE_API_KEY=REMOVED
# FIREBASE_AUTH_DOMAIN=REMOVED
# FIREBASE_PROJECT_ID=REMOVED
# FIREBASE_STORAGE_BUCKET=REMOVED

# Dummy/Placeholder values are rejected
# DUMMY values like "_DUMMY_API_KEY_" will cause startup failure
# ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // SOVEREIGN NAMESPACE RULES
    // Only users holding a valid custom token for the exact workspaceId can access data.

    // 1. Core Workspace Metadata
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && request.auth.token.workspaceId == workspaceId;
      // Writes are strictly reserved for the Cloud Functions (Admin SDK) during provisioning
      allow write: if false; 
    }

    // 2. Workspace Membership Records
    match /workspaceMembers/{recordId} {
      // The frontend can verify its own membership record
      allow read: if request.auth != null && resource.data.workspaceId == request.auth.token.workspaceId;
      allow write: if false; 
    }

    // 3. Workspace Apps (Isolated Data)
    match /workspaceApps/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.workspaceId == workspaceId;
    }

    // 4. Workspace Memory (Isolated State)
    match /workspaceMemory/{workspaceId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.workspaceId == workspaceId;
    }
  }
}
